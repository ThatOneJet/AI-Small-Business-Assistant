# JetCore online database (Supabase) — copy this file to  .env  and fill in your values.
#
# Without these, the app runs LOCAL-ONLY (the "disconnected / fresh download" state).
# With them, the designed architecture kicks in:
#   • all business data (sales, labor, finances, transactions) stays LOCAL
#   • only API tokens/credentials are synced to the cloud — end-to-end ENCRYPTED
#     (Supabase only ever stores ciphertext; see frontend/src/main/vault.ts)
#
# Get these from your Supabase project:  Dashboard → Project Settings → API
#   - Project URL           →  SUPABASE_URL
#   - Project API key "anon / publishable"  →  SUPABASE_ANON_KEY   (public key; safe on the client)
#   - Do NOT use the service_role key here.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-PUBLISHABLE-KEY

# Optional — only if you also want Summit's backend DB (SQLAlchemy) on Postgres instead
# of local sqlite. Leave unset to keep Summit's data on the local file (recommended,
# matches "keep data local"). Format:
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
