# ═══════════════════════════════════════════════════════════════════════
#  Monorepo for JetCore (Summit) + TradingSimulator.
#  Commit source only — dependencies, build output, data and secrets are ignored.
# ═══════════════════════════════════════════════════════════════════════

# ── Dependencies (restore with `npm install`) ──────────────────────────
node_modules/
**/node_modules/

# ── Python caches ──────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Build artifacts (regenerate with `npm run build`) ──────────────────
dist/
dist-electron/
**/frontend/dist/

# ── Runtime data, models, logs (regenerate on first run) ───────────────
*.db
*.sqlite
*.sqlite3
*.joblib
**/ticker_db.json
**/llm_data/
**/trading_model_samples.jsonl
*.log
backend.out

# ── Secrets — NEVER commit ─────────────────────────────────────────────
.env
*.env
**/.env

# ── OS / editor ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
